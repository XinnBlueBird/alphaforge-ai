# AlphaForge AI — Environment

# ─── LLM Backend (server-side only — NEVER commit a real value) ───
# Public docs surface this as "MiMo V2.5 Pro". Internally any OpenAI-compatible
# endpoint works (FreeModel, OpenRouter, self-hosted vLLM, etc).
FREEMODEL_API_KEY=fe_oa_your_freemodel_key_here

# Optional overrides
MIMO_API_BASE=https://api.freemodel.dev/v1
MIMO_MODEL=mimo/mimo-v2.5-pro

# Override the model used for /api/signal specifically (defaults to claude-opus-4-7
# if FREEMODEL_API_KEY points at FreeModel, otherwise falls back to MIMO_MODEL).
SIGNAL_MODEL=claude-opus-4-7

# ─── UI ───
# What the user-facing badge says. Keep this as MiMo V2.5 Pro for public deploys.
NEXT_PUBLIC_MODEL_LABEL=MiMo V2.5 Pro
