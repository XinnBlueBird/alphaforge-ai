# AlphaForge AI — Environment

# ─── LLM Backend (server-side only — NEVER commit a real value) ───
# Powered by Xiaomi MiMo V2.5 Pro via the official MiMo API Open Platform.
# Get your key at https://platform.xiaomimimo.com (Console → API Keys).
MIMO_API_KEY=sk-...your-mimo-key

# Optional overrides
MIMO_API_BASE=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Override the model used for /api/signal + /api/scan + /api/compose specifically.
# Defaults to mimo-v2.5-pro.
SIGNAL_MODEL=mimo-v2.5-pro

# ─── UI ───
# What the user-facing badge says. Keep this as MiMo V2.5 Pro for public deploys.
NEXT_PUBLIC_MODEL_LABEL=MiMo V2.5 Pro
